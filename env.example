# ── Gemini API (FREE - no credit card needed) ──────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Email alerts (Gmail) ───────────────────────────────────────────────────
ALERT_EMAIL_FROM=yourgmail@gmail.com
ALERT_EMAIL_PASSWORD=your_gmail_app_password_here
ALERT_EMAIL_TO=youremail@example.com

# ── Describe YOUR business here ────────────────────────────────────────────
SYSTEM_PROMPT=You are a helpful customer support assistant for [Your Business Name]. [Describe what you do, your products/services, hours, return policy, contact email, etc.]. Be warm, friendly, and concise. If you don't know something specific, say so honestly.

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001
